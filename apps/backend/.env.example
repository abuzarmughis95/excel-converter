# Ledgerline backend environment (copy to .env for local development).
# Never commit a real .env. Secrets are loaded from the environment only.

LEDGERLINE_ENVIRONMENT=development
LEDGERLINE_LOG_LEVEL=INFO
LEDGERLINE_LOG_JSON=false
LEDGERLINE_SERVICE_NAME=ledgerline-backend

# Comma-separated browser origins permitted by CORS (empty by default).
# LEDGERLINE_CORS_ALLOWED_ORIGINS=["http://localhost:5173"]

# SQLAlchemy database URL. Defaults to the docker-compose Postgres for dev.
# For a quick local run without Postgres you may use SQLite:
#   LEDGERLINE_DATABASE_URL=sqlite:///./ledgerline.sqlite
LEDGERLINE_DATABASE_URL=postgresql+psycopg://ledgerline:ledgerline_dev_only@localhost:5433/ledgerline

# Authentication. JWT secret MUST be set to a strong value in production
# (startup is rejected otherwise). TTLs are in seconds.
# LEDGERLINE_JWT_SECRET=replace-with-a-strong-random-32+byte-secret
# LEDGERLINE_ACCESS_TOKEN_TTL_SECONDS=900
# LEDGERLINE_REFRESH_TOKEN_TTL_SECONDS=1209600
# LEDGERLINE_MAX_FAILED_LOGINS=5
# LEDGERLINE_LOCKOUT_SECONDS=900

# Set false for invitation-only deployments (disables POST /auth/register).
# LEDGERLINE_ALLOW_OPEN_REGISTRATION=true
# Per-IP login throttling.
# LEDGERLINE_LOGIN_IP_MAX_ATTEMPTS=20
# LEDGERLINE_LOGIN_IP_WINDOW_SECONDS=300

# How long a registered device may operate offline before re-checking its
# entitlement (default 30 days, in seconds).
# LEDGERLINE_DEVICE_ENTITLEMENT_TTL_SECONDS=2592000

# OpenAI — bank statement extraction (vision OCR). Optional; the feature is
# disabled (503) when unset. Never commit a real key.
# LEDGERLINE_OPENAI_API_KEY=sk-...
# LEDGERLINE_OPENAI_MODEL=gpt-4o-mini
