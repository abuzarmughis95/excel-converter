{
  "name": "ledgerline",
  "version": "0.0.0",
  "private": true,
  "description": "Ledgerline — offline-first UK accounting & compliance platform",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rimraf node_modules",
    "format": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "format:write": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "@eslint/js": "9.11.1",
    "eslint": "9.11.1",
    "eslint-config-prettier": "9.1.0",
    "prettier": "3.3.3",
    "rimraf": "6.0.1",
    "turbo": "2.1.3",
    "typescript": "5.6.2",
    "typescript-eslint": "8.8.0"
  }
}
